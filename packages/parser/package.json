{
  "name": "@word-auto/parser",
  "version": "0.0.1",
  "description": "解析 .docx (OOXML) 为带样式继承的文档模型，不依赖 Word/COM",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
